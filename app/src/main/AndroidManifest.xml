<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Required to ignore battery optimizations so the accessibility service stays alive -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <!-- Required for Open-Meteo weather API calls -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Required for the companion KeepAliveService that anchors the process at foreground priority -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Explicitly remove AD_ID permissions injected by Firebase Analytics — FocusLock has
         no ad-targeting use case and disables adid collection via the meta-data flag below. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_AD_ID" tools:node="remove" />
    <uses-permission android:name="android.permission.ACCESS_ADSERVICES_ATTRIBUTION" tools:node="remove" />
    <!-- API 34+: foregroundServiceType="specialUse" requires this permission -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- API 33+: required to post the persistent KeepAlive notification -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".FocusLockApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:localeConfig="@xml/locale_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FocusLock">

        <!-- Opt out of Firebase Analytics advertising ID collection.
             The app has no ad targeting use case; this removes the AD_ID permission
             from the merged manifest and simplifies the Play Console data safety declaration. -->
        <meta-data
            android:name="google_analytics_adid_collection_enabled"
            android:value="false" />

        <!-- Entry point — shows settings and guides the user to enable the accessibility service -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.FocusLock"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Accessibility service that draws the lock screen overlay via TYPE_ACCESSIBILITY_OVERLAY.
             This type is placed above the keyguard without requiring SYSTEM_ALERT_WINDOW.
             The system binds and keeps this service alive at high priority while it is
             enabled in Settings, so it does NOT call startForeground(): doing so with a
             dataSync type breaks restarts on API 34+ (wrong type) and hits the 6h/day
             timeout on API 35+. The service restarts automatically after reboot because
             Android preserves accessibility settings across reboots. -->
        <service
            android:name=".service.FocusLockAccessibilityService"
            android:exported="true"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            tools:ignore="AccessibilityPolicy">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Companion foreground service that keeps the process alive at foreground priority.
             Prevents aggressive OEM killers (MIUI, One UI) from terminating the process
             that hosts FocusLockAccessibilityService. Uses specialUse type (API 34+) to
             avoid the 6h/day dataSync cap and the wrong-type restart failures. -->
        <service
            android:name=".service.KeepAliveService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Companion keepalive service. Maintains the accessibility service process alive on OEM devices with aggressive battery management. No user data is collected or processed." />
        </service>

    </application>

</manifest>
